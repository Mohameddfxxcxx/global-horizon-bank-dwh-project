# =============================================================================
# Global Horizon Bank — gitignore
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Environment / secrets
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Database files
*.db
*.sqlite3
*.mdf
*.ldf

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Build / model artifacts
.pdf
*.pdf
.ipynb_checkpoints/

# Pytest / mypy / ruff caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Derived medallion artifacts (regenerable from data/raw/)
data/bronze/*
!data/bronze/.gitkeep
data/silver/*
!data/silver/.gitkeep
data/gold/*
!data/gold/.gitkeep

# Runtime logs
logs/*
!logs/.gitkeep

# Generated diagram artifacts
streamlit.png

# Claude Code harness state
.claude/
